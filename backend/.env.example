# ─── Application ────────────────────────────────────────────────────────────────
APP_NAME=ManimAI
APP_VERSION=2.0.0
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# ─── Database — Supabase Postgres ───────────────────────────────────────────────
# Find in: Supabase Dashboard → Project Settings → Database → Connection string
# Use direct connection (port 5432) rather than pooler (port 6543) for asyncpg support.
# Async driver (FastAPI runtime):
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
# Sync driver (Celery workers / Alembic):
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# ─── Redis — Upstash (use rediss:// for TLS) ────────────────────────────────────
# Get from: https://console.upstash.com → Redis → Connect → REST or Redis CLI URL
REDIS_URL=rediss://default:your-redis-token@your-redis-endpoint.upstash.io:6379
CELERY_BROKER_URL=rediss://default:your-redis-token@your-redis-endpoint.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:your-redis-token@your-redis-endpoint.upstash.io:6379

# ─── Gemini LLMs ────────────────────────────────────────────────────────────────
# Get your API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Lighter model — for script generation + code review (fast, cheap)
LIGHT_LLM_MODEL=gemini-3.1-flash-lite
LIGHT_LLM_TEMPERATURE=0.4
LIGHT_LLM_MAX_TOKENS=8192 

# Heavier model — for Manim code gen + error fixing (powerful)
HEAVY_LLM_MODEL=gemini-3.5-flash
HEAVY_LLM_TEMPERATURE=0.2
HEAVY_LLM_MAX_TOKENS=21536

# ─── Supabase Auth (OAuth verification) ─────────────────────────────────────────
# Find in: Supabase Dashboard → Project Settings → API
# And enable the auth servises on supabase (google and github) 
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Cloudinary (video storage) ─────────────────────────────────────────────────
# Sign up free: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── Storage ─────────────────────────────────────────────────────────────────────
MEDIA_DIR=./media

# ─── Rate Limiting ────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ─── CORS ─────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Manim ────────────────────────────────────────────────────────────────────────
MANIM_TIMEOUT_SECONDS=360

# ─── Pipeline Smart Retry ─────────────────────────────────────────────────────────
MAX_COMPILE_RETRIES=3
MAX_PIPELINE_RETRIES=2
LLM_TIMEOUT_SECONDS=180
